---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, getPostUrl, getPosts, getReadingTime, getTagUrl } from '../../lib/blog';

export async function getStaticPaths({ paginate }) {
  const posts = await getPosts();
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
const siteTitle = "Daniele 'eriol' Tricoli Website";

function pageUrl(pageNumber: number) {
  return pageNumber === 1 ? '/blog/' : `/blog/${pageNumber}/`;
}
---
<BaseLayout title={`Blog posts - ${siteTitle}`}>
  <div class="row">
    <div class="d-grid gap-4">
      {page.data.map((post) => (
        <section>
          <header>
            <h2><a href={getPostUrl(post.slug)}>{post.data.title}</a></h2>
            <span>
              {formatDate(post.data.date)} &middot; {getReadingTime(post.body)} minute read
            </span>
          </header>
          {post.data.description && <p>{post.data.description}</p>}
          {post.data.tags.length > 0 && (
            <ul class="list-unstyled">
              <li>
                Tags:{' '}
                {post.data.tags.map((tag) => (
                  <span class="badge bg-secondary me-1">
                    <a href={getTagUrl(tag)}>#{tag}</a>
                  </span>
                ))}
              </li>
            </ul>
          )}
          <a class="no-underline" href={getPostUrl(post.slug)}>Read full entry &rarr;</a>
        </section>
      ))}
    </div>
  </div>

  <div class="row justify-content-md-center">
    <div class="col-md-auto">
      <nav id="footer-nav" aria-label="Page navigation">
        <ul class="pagination">
          <li class="page-item">
            <a href={pageUrl(1)} class="page-link" aria-label="First"><span aria-hidden="true">&laquo;&laquo;</span></a>
          </li>
          <li class:list={['page-item', !page.url.prev && 'disabled']}>
            <a href={page.url.prev ?? undefined} class="page-link" aria-label="Previous"><span aria-hidden="true">&laquo;</span></a>
          </li>
          {Array.from({ length: page.lastPage }, (_, index) => index + 1).map((pageNumber) => (
            <li class:list={['page-item', pageNumber === page.currentPage && 'active']}>
              <a class="page-link" href={pageUrl(pageNumber)}>{pageNumber}</a>
            </li>
          ))}
          <li class:list={['page-item', !page.url.next && 'disabled']}>
            <a href={page.url.next ?? undefined} class="page-link" aria-label="Next"><span aria-hidden="true">&raquo;</span></a>
          </li>
          <li class="page-item">
            <a href={pageUrl(page.lastPage)} class="page-link" aria-label="Last"><span aria-hidden="true">&raquo;&raquo;</span></a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</BaseLayout>
